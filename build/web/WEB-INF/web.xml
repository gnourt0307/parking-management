<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet-mapping>
        <servlet-name>DashboardController</servlet-name>
        <url-pattern>/Dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UsersController</servlet-name>
        <url-pattern>/Users</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ZonesController</servlet-name>
        <url-pattern>/Zones</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SlotsController</servlet-name>
        <url-pattern>/Slots</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PricingController</servlet-name>
        <url-pattern>/Pricing</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ReportController</servlet-name>
        <url-pattern>/Report</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>VehicleInController</servlet-name>
        <url-pattern>/VehicleIn</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>VehicleOutController</servlet-name>
        <url-pattern>/VehicleOut</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProfileController</servlet-name>
        <url-pattern>/Profile</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>HistoryController</servlet-name>
        <url-pattern>/History</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    <error-page>
        <error-code>403</error-code>
        <location>/views/errors/403.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/views/errors/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/views/errors/500.jsp</location>
    </error-page>
    <servlet>
        <servlet-name>DashboardController</servlet-name>
        <servlet-class>controllers.admin.DashboardController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UsersController</servlet-name>
        <servlet-class>controllers.admin.UsersController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ZonesController</servlet-name>
        <servlet-class>controllers.admin.ZonesController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SlotsController</servlet-name>
        <servlet-class>controllers.admin.SlotsController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PricingController</servlet-name>
        <servlet-class>controllers.admin.PricingController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ReportController</servlet-name>
        <servlet-class>controllers.admin.ReportController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VehicleInController</servlet-name>
        <servlet-class>controllers.staff.VehicleInController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VehicleOutController</servlet-name>
        <servlet-class>controllers.staff.VehicleOutController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StaffHistoryController</servlet-name>
        <servlet-class>controllers.staff.StaffHistoryController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProfileController</servlet-name>
        <servlet-class>controllers.customer.ProfileController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>HistoryController</servlet-name>
        <servlet-class>controllers.customer.HistoryController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StaffHistoryController</servlet-name>
        <url-pattern>/StaffHistory</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/Login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegisterController</servlet-name>
        <url-pattern>/Register</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/Logout</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>controllers.auth.LoginController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegisterController</servlet-name>
        <servlet-class>controllers.auth.RegisterController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>controllers.auth.LogoutController</servlet-class>
    </servlet>
</web-app>
